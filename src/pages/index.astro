---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getSortedPosts } from '../lib/posts';
import { CATEGORIES, CATEGORY_LABELS } from '../content.config';

const posts = await getSortedPosts();
---

<BaseLayout>
  <section class="hero">
    <div class="container">
      <span class="kicker">For those living in The Netherlands 🇳🇱 </span>
      <h1>Boring my friends, <span class="accent">padding our wallets.</span></h1>
      <p>
        okmate is a blog created by Jack as an outlet to place my somewhat 
        thesis like findings when it comes to saving money in The Netherlands.
        When I tell my friends about a way I've collected points through my
        regular shopping and spent them on a flight to Seoul, they ask how?
        I explain, they get bored of me talking and say: "Ok mate... thanks."
        </br>This blog is for those who want in. But at their own pace.
      </p>
    </div>
  </section>

  <section class="container">
    <div class="tabs" role="tablist" aria-label="Filter articles by category">
      <button class="tab active" data-filter="all" type="button">All</button>
      {
        CATEGORIES.map((cat) => (
          <button class="tab" data-filter={cat} type="button">
            {CATEGORY_LABELS[cat]}
          </button>
        ))
      }
    </div>

    <div class="section-head">
      <h2>Latest</h2>
    </div>

    <div class="grid" id="article-grid">
      {
        posts.map((post) => (
          <ArticleCard
            slug={post.id}
            title={post.data.title}
            date={post.data.date}
            summary={post.data.summary}
            categories={post.data.categories}
            image={post.data.image}
          />
        ))
      }
    </div>
    <p class="empty" id="empty-state" hidden>No posts in this category yet. Have a litte... patience.</p>
  </section>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7716561967301995"
     crossorigin="anonymous"></script>
<!-- Horizontal Home Page -->
<ins class="adsbygoogle"
     style="display:block"
     data-ad-client="ca-pub-7716561967301995"
     data-ad-slot="9163576127"
     data-ad-format="auto"
     data-full-width-responsive="true"></ins>
<script>
     (adsbygoogle = window.adsbygoogle || []).push({});
</script>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab');
  const cards = document.querySelectorAll<HTMLElement>('#article-grid .card');
  const empty = document.getElementById('empty-state');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');
      const filter = tab.dataset.filter;
      let visible = 0;
      cards.forEach((card) => {
        const match = filter === 'all' || card.dataset.category === filter;
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      if (empty) empty.hidden = visible !== 0;
    });
  });
</script>
