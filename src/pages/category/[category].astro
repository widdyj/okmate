---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { CATEGORIES, CATEGORY_LABELS } from '../../content.config';

export const prerender = true;

export async function getStaticPaths() {
  return CATEGORIES.map((category) => ({
    params: { category },
  }));
}

const { category } = Astro.params;
const label = CATEGORY_LABELS[category as keyof typeof CATEGORY_LABELS];

const all = await getCollection('posts');
const posts = all
  .filter((p) => p.data.categories === category)
  .sort(
    (a, b) =>
      new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  );
---

<BaseLayout title={`${label} — okmate.nl`} description={`All ${label} posts from okmate.nl.`}>
  <section class="hero">
    <div class="container">
      <span class="kicker">Category</span>
      <h1 class="accent">{label}</h1>
      <p>
        {posts.length} {posts.length === 1 ? 'post' : 'posts'} filed under {label}.
      </p>
    </div>
  </section>

  <section class="container">
    {
      posts.length > 0 ? (
        <div class="grid">
          {posts.map((post) => (
            <ArticleCard
              slug={post.id}
              title={post.data.title}
              date={post.data.date}
              summary={post.data.summary}
              categories={post.data.categories}
              image={post.data.image}
            />
          ))}
        </div>
      ) : (
        <p class="empty">Nothing here yet. Check back soon.</p>
      )
    }
  </section>
</BaseLayout>
