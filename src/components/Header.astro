---
const links = [
  { href: '/', label: 'Home' },
  { href: '/category/points-miles', label: 'Points & Miles' },
  { href: '/category/personal-finance', label: 'Finance' },
  { href: '/category/deals', label: 'Deals' },
  { href: '/about', label: 'About' },
];
---

<header class="site-header">
  <div class="container inner">
    <a href="/" class="logo">okmate<span class="dot"></span></a>
    <nav class="nav" aria-label="Primary">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
  </div>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7716561967301995"
     crossorigin="anonymous"></script>
</header>
