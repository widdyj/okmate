---
const links = [
  { href: '/', label: 'Home' },
  { href: '/category/points-miles', label: 'Points & Miles' },
  { href: '/category/financial-hacks', label: 'Hacks' },
  { href: '/category/deals', label: 'Deals' },
  { href: '/about', label: 'About' },
];
---

<header class="site-header">
  <div class="container inner">
    <a href="/" class="logo">okmate<span class="dot">.nl</span></a>
    <nav class="nav" aria-label="Primary">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
  </div>
</header>
