{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "categories": {
      "type": "string",
      "enum": [
        "points-miles",
        "personal-finance",
        "deals",
        "general-tips"
      ]
    },
    "image": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date",
    "summary",
    "categories"
  ]
}